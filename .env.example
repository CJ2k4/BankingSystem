# Copy to .env and adjust. .env is gitignored.

# --- Database ---
POSTGRES_DB=banking
POSTGRES_USER=banking
POSTGRES_PASSWORD=banking
# Host port is 5433 (mapped to the container's 5432) to avoid clashing with a local Postgres.
DB_URL=jdbc:postgresql://localhost:5433/banking
DB_USERNAME=banking
DB_PASSWORD=banking

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Security (Phase 1) ---
# Secret must be >= 32 chars (HS256). TTLs use Spring duration format (e.g. 15m, 7d).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Demo admin seeded at startup
ADMIN_EMAIL=admin@bank.local
ADMIN_PASSWORD=Admin123!

# --- Stripe (test mode, set in Phase 4) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Kafka (Phase 6) ---
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Email (Phase 6, optional) — set SPRING_MAIL_HOST to enable real SMTP (e.g. Mailtrap) ---
# SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=
MAIL_FROM=no-reply@bank.local

# --- Frontend ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080

# --- Production (Phase 7) — set these on the host (Railway/Vercel), not committed ---
# SPRING_PROFILES_ACTIVE=prod
# SEED_DEMO=true                 # seed demo@bank.local / Demo123! with sample data
# RATELIMIT_AUTH_PER_MINUTE=10
# CORS_ALLOWED_ORIGINS=https://<your-app>.vercel.app
# VITE_API_BASE_URL=https://<your-backend>.up.railway.app   # frontend build-time
