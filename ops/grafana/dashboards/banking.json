{
  "title": "Banking System — Overview",
  "uid": "banking-overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Service up",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=\"banking-backend\"}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (uri)", "refId": "A", "legendFormat": "{{uri}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "refId": "A" }
      ]
    }
  ]
}
